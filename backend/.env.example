# Database
DATABASE_URL=postgresql://<db_user>:<db_password>@localhost:5432/<db_name>

# MinIO / Object Storage
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=<minio_access_key>
MINIO_SECRET_KEY=<minio_secret_key>
MINIO_BUCKET_NAME=supplier-documents
MINIO_USE_SSL=false

# JWT Secret
JWT_SECRET_KEY=<replace-with-your-jwt-secret>
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Application
APP_ENV=development
DEBUG=true

# PMC / Gmail
FRONTEND_BASE_URL=http://localhost:3000
GMAIL_OAUTH_CALLBACK_PATH=/api/pmc/gmail/oauth/callback
PMC_INVENTORY_ADJUSTMENT_SENDERS=
PMC_INVENTORY_ADJUSTMENT_SUBJECT_KEYWORDS=库存异动,领料通知,借料通知,归还通知,入库通知,报废通知

# AI
AI_API_KEY=<your_ai_api_key>
AI_BASE_URL=https://your-ai-endpoint.example.com/v1
AI_MODEL=gpt-4o
PMC_INVENTORY_ADJUSTMENT_AI_ENABLED=true
